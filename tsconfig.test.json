{
  "compilerOptions": {
    "target": "ES2022",
    "module": "Node16",
    "moduleResolution": "Node16",
    "lib": ["DOM", "ES2022"],
    "types": ["node"],
    "strict": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "rootDir": ".",
    "outDir": "dist-test"
  },
  "include": [
    "src/main/ipcValidation.ts",
    "src/renderer/keybindings.ts",
    "src/shared/**/*.ts",
    "tests/**/*.test.ts"
  ]
}
