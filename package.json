{
  "name": "morphterm",
  "version": "0.1.0-alpha",
  "description": "An open-source customizable desktop terminal inspired by Hyper.",
  "main": "dist/main/main.js",
  "scripts": {
    "dev": "concurrently -k \"npm:dev:renderer\" \"npm:dev:electron\"",
    "dev:renderer": "vite --host 127.0.0.1",
    "dev:electron": "wait-on http://127.0.0.1:5173 && tsc -p tsconfig.electron.json && electron .",
    "build": "tsc -p tsconfig.electron.json && vite build",
    "dist:win": "npm run build && electron-builder --win portable --config.win.signAndEditExecutable=false",
    "dist:win:release": "npm run build && electron-builder --win portable --config electron-builder.release.cjs",
    "test": "tsc -p tsconfig.test.json && node --test \"dist-test/tests/**/*.test.js\"",
    "typecheck": "tsc --noEmit -p tsconfig.electron.json && tsc --noEmit -p tsconfig.renderer.json"
  },
  "keywords": [
    "electron",
    "terminal",
    "react",
    "typescript"
  ],
  "author": "",
  "license": "MIT",
  "build": {
    "appId": "com.morphterm.app",
    "productName": "MorphTerm",
    "files": [
      "dist/**/*",
      "package.json"
    ],
    "asar": true,
    "asarUnpack": [
      "node_modules/node-pty/build/Release/*.node"
    ],
    "afterPack": "scripts/after-pack.cjs",
    "directories": {
      "output": "release"
    },
    "win": {
      "icon": "public/app-icon.ico",
      "signAndEditExecutable": true,
      "target": [
        "portable"
      ],
      "artifactName": "${productName}-${version}-${arch}.${ext}"
    }
  },
  "dependencies": {
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "node-pty": "^1.1.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@electron/fuses": "^1.8.0",
    "@types/node": "^20.17.6",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.3",
    "concurrently": "^9.1.0",
    "electron": "^28.3.3",
    "electron-builder": "^24.13.3",
    "typescript": "^5.6.3",
    "vite": "^5.4.11",
    "wait-on": "^8.0.1"
  },
  "overrides": {
    "shell-quote": "1.8.4"
  }
}
